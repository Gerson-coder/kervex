---
---
<div id="cursor-glow" aria-hidden="true"></div>

<script>
  const glow = document.getElementById('cursor-glow');
  if (!glow || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    if (glow) glow.style.display = 'none';
  } else {
    let mouseX = -500;
    let mouseY = -500;
    let curX = -500;
    let curY = -500;
    let rafId = 0;

    function animate() {
      // Lerp suave para movimiento orgánico
      curX += (mouseX - curX) * 0.08;
      curY += (mouseY - curY) * 0.08;

      glow.style.background = `
        radial-gradient(300px circle at ${curX}px ${curY}px,
          rgba(0, 229, 255, 0.18) 0%,
          rgba(0, 229, 255, 0.08) 25%,
          rgba(0, 184, 212, 0.04) 45%,
          transparent 70%
        ),
        radial-gradient(200px circle at ${curX + 20}px ${curY - 15}px,
          rgba(255, 10, 255, 0.06) 0%,
          transparent 60%
        ),
        radial-gradient(150px circle at ${curX - 25}px ${curY + 20}px,
          rgba(0, 255, 136, 0.04) 0%,
          transparent 50%
        )
      `;

      rafId = requestAnimationFrame(animate);
    }

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    document.addEventListener('mouseleave', () => {
      mouseX = -500;
      mouseY = -500;
    });

    rafId = requestAnimationFrame(animate);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId);
    }, { once: true });
  }
</script>

<style>
  #cursor-glow {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1;
    pointer-events: none;
  }
</style>
