---
<div id="cursor-grid" aria-hidden="true"></div>

<script>
  const grid = document.getElementById('cursor-grid');
  if (!grid || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    if (grid) grid.style.display = 'none';
  } else {
    const TILE_SIZE = 48;
    const RADIUS = 200;
    const RADIUS_SQ = RADIUS * RADIUS;

    let cols = 0;
    let rows = 0;
    let tiles: HTMLDivElement[] = [];
    let mouseX = -1000;
    let mouseY = -1000;
    let rafId = 0;

    function buildGrid() {
      const w = window.innerWidth;
      const h = window.innerHeight;
      cols = Math.ceil(w / TILE_SIZE);
      rows = Math.ceil(h / TILE_SIZE);
      const total = cols * rows;

      while (tiles.length > total) {
        const t = tiles.pop();
        if (t) grid.removeChild(t);
      }
      while (tiles.length < total) {
        const t = document.createElement('div');
        t.className = 'cg-tile';
        grid.appendChild(t);
        tiles.push(t);
      }

      grid.style.gridTemplateColumns = `repeat(${cols}, ${TILE_SIZE}px)`;
      grid.style.gridTemplateRows = `repeat(${rows}, ${TILE_SIZE}px)`;
    }

    function updateTiles() {
      for (let i = 0; i < tiles.length; i++) {
        const col = i % cols;
        const row = Math.floor(i / cols);
        const cx = col * TILE_SIZE + TILE_SIZE / 2;
        const cy = row * TILE_SIZE + TILE_SIZE / 2;
        const dx = mouseX - cx;
        const dy = mouseY - cy;
        const distSq = dx * dx + dy * dy;

        if (distSq < RADIUS_SQ) {
          const dist = Math.sqrt(distSq);
          const intensity = 1 - dist / RADIUS;
          const opacity = intensity * intensity * 0.35;
          tiles[i].style.opacity = String(opacity);
          tiles[i].style.boxShadow = `inset 0 0 ${12 * intensity}px rgba(0,229,255,${opacity * 0.8})`;
        } else {
          tiles[i].style.opacity = '0';
          tiles[i].style.boxShadow = 'none';
        }
      }
      rafId = requestAnimationFrame(updateTiles);
    }

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    document.addEventListener('mouseleave', () => {
      mouseX = -1000;
      mouseY = -1000;
    });

    window.addEventListener('resize', buildGrid);

    buildGrid();
    rafId = requestAnimationFrame(updateTiles);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId);
    }, { once: true });
  }
</script>

<style>
  #cursor-grid {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 1;
    pointer-events: none;
    display: grid;
    overflow: hidden;
  }

  .cg-tile {
    background: rgba(0, 229, 255, 0.06);
    border: 1px solid rgba(0, 229, 255, 0.03);
    opacity: 0;
    transition: opacity 0.15s ease;
  }
</style>
