<canvas id="neon-bg" aria-hidden="true"></canvas>

<script>
  import { NeonGrid } from '../../lib/three/neonGrid';

  const canvas = document.getElementById('neon-bg') as HTMLCanvasElement;
  if (canvas && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    new NeonGrid(canvas);
  }
</script>

<style>
  #neon-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.35;
  }
</style>
