<div id="robo">
  <div id="robo-bubble"></div>
  <canvas id="robot-canvas" width="60" height="72" aria-hidden="true"></canvas>
</div>

<script>
  import { RobotScene } from '../../lib/three/robotScene';

  const canvas = document.getElementById('robot-canvas') as HTMLCanvasElement;
  if (canvas && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    new RobotScene(canvas);
  }
</script>
