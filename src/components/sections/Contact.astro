<div class="sec" id="contacto" style="padding-top:0">
  <div class="divrow"><span class="dl"></span><span class="dt">Canal de comunicación</span><span class="dl"></span></div>
  <div class="shdr">
    <div class="eyebrow">Diagnóstico gratuito</div>
    <h2 class="sh">Empezá a automatizar<br><span class="neon">tu empresa hoy</span></h2>
    <p class="ssub">Completá el formulario y te contactamos en menos de 24 horas por WhatsApp.</p>
  </div>
  <div class="contact-wrap" style="position:relative">
    <div class="bracket tl"></div><div class="bracket tr"></div>
    <div class="bracket bl"></div><div class="bracket br"></div>
    <form class="contact-form" action="https://formspree.io/PLACEHOLDER" method="POST">
      <div class="form-grid">
        <div class="form-group">
          <label class="form-label">Nombre completo</label>
          <input type="text" name="nombre" class="form-input" placeholder="Tu nombre" required />
        </div>
        <div class="form-group">
          <label class="form-label">Empresa</label>
          <input type="text" name="empresa" class="form-input" placeholder="Nombre de tu empresa" required />
        </div>
        <div class="form-group">
          <label class="form-label">WhatsApp <span style="color:var(--neon)">*</span></label>
          <input type="tel" name="whatsapp" class="form-input" placeholder="+51 9XX XXX XXX" required />
        </div>
        <div class="form-group">
          <label class="form-label">Rubro / Sector</label>
          <input type="text" name="rubro" class="form-input" placeholder="Ej: Retail, Logística, Manufactura" />
        </div>
      </div>
      <div class="form-group" style="margin-top:16px">
        <label class="form-label">¿Qué proceso querés automatizar?</label>
        <textarea name="mensaje" class="form-input form-textarea" placeholder="Contanos brevemente qué tareas manuales te gustaría eliminar..." rows="4"></textarea>
      </div>
      <div class="form-footer">
        <button type="submit" class="btn-neon">Solicitar diagnóstico gratis →</button>
        <span class="form-note">Sin compromiso · Respondemos en &lt;24h por WhatsApp</span>
      </div>
    </form>
  </div>
</div>
