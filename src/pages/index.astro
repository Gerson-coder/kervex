---
import BaseLayout from '../layouts/BaseLayout.astro';
import NeonCanvas from '../components/shared/NeonCanvas.astro';
import FloatingRobot from '../components/shared/FloatingRobot.astro';
import Nav from '../components/layout/Nav.astro';
import Hero from '../components/sections/Hero.astro';
import Problems from '../components/sections/Problems.astro';
import Simulator from '../components/sections/Simulator.astro';
import Process from '../components/sections/Process.astro';
import Pricing from '../components/sections/Pricing.astro';
import CtaBand from '../components/sections/CtaBand.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout>
  <NeonCanvas />
  <FloatingRobot />
  <Nav />
  <div class="wrap">
    <Hero />
    <Problems />
    <Simulator />
    <Process />
    <Pricing />
    <CtaBand />
  </div>
  <Footer />
</BaseLayout>
